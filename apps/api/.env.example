# API server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Postgres
DATABASE_URL=postgresql://directport:directport@localhost:5434/directport

# Redis (BullMQ queues)
REDIS_URL=redis://localhost:6380

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXPIRATION=15m

# Internal API key (service-to-service: bot -> API)
API_INTERNAL_KEY=change-me-to-a-random-key

# TKS API (api1.tks.ru)
TKS_API_BASE_URL=https://api1.tks.ru
TKS_TNVED_API_KEY=
TKS_GOODS_API_KEY=
# TTL кэша ответов TKS API в миллисекундах (по умолчанию 24 часа)
TKS_CACHE_TTL_MS=86400000

# Anthropic Claude (optional, for ТН ВЭД verification)
ANTHROPIC_API_KEY=
